{
  "name": "cf-hono-supabase-api-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal Cloudflare Worker API with Hono and Supabase Auth. Pairs with react-supabase-auth-template.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-templates/cf-hono-supabase-api-template.git"
  },
  "homepage": "https://github.com/open-templates/cf-hono-supabase-api-template#readme",
  "bugs": {
    "url": "https://github.com/open-templates/cf-hono-supabase-api-template/issues"
  },
  "license": "MIT",
  "scripts": {
    "init": "node scripts/init-from-template.mjs",
    "build": "tsc",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "hono": "^4.1.0",
    "@supabase/supabase-js": "^2.38.0",
    "zod": "^3.22.4",
    "@hono/zod-validator": "^0.2.0",
    "jose": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "globals": "^15.14.0",
    "wrangler": "^4.97.0",
    "typescript": "^5.3.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.0"
  }
}
